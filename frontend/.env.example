# Frontend Environment Variables
# Copy to .env and fill in your Firebase config

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# API URL: Use /api for local dev (Vite proxy), or your Render backend URL for production
# Local: VITE_API_URL=/api
# Production: VITE_API_URL=https://your-backend.onrender.com/api
VITE_API_URL=/api

# Backend Socket.IO URL (only needed for production, leave empty for local dev)
# Production: VITE_SOCKET_URL=https://your-backend.onrender.com
VITE_SOCKET_URL= 
